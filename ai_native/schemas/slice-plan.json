{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["title", "summary", "slices"],
  "properties": {
    "title": { "type": "string" },
    "summary": { "type": "string" },
    "slices": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "name",
          "goal",
          "acceptance_criteria",
          "file_impact",
          "test_plan",
          "dependencies"
        ],
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "goal": { "type": "string" },
          "acceptance_criteria": {
            "type": "array",
            "items": { "type": "string" }
          },
          "file_impact": {
            "type": "array",
            "items": { "type": "string" }
          },
          "test_plan": {
            "type": "array",
            "items": { "type": "string" }
          },
          "dependencies": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    }
  }
}

