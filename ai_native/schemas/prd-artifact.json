{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "title",
    "user_value",
    "scope",
    "constraints",
    "acceptance_criteria",
    "out_of_scope"
  ],
  "properties": {
    "title": { "type": "string" },
    "user_value": { "type": "string" },
    "scope": {
      "type": "array",
      "items": { "type": "string" }
    },
    "constraints": {
      "type": "array",
      "items": { "type": "string" }
    },
    "acceptance_criteria": {
      "type": "array",
      "items": { "type": "string" }
    },
    "out_of_scope": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}

