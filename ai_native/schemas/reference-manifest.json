{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["workflow_profile", "references", "preview"],
  "properties": {
    "workflow_profile": {
      "type": "string",
      "enum": ["reference_driven_web"]
    },
    "references": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "label", "kind", "route", "viewport"],
        "properties": {
          "id": { "type": "string" },
          "label": { "type": "string" },
          "kind": {
            "type": "string",
            "enum": ["image", "html_export", "url"]
          },
          "route": { "type": "string" },
          "viewport": {
            "type": "object",
            "additionalProperties": false,
            "required": ["width", "height"],
            "properties": {
              "width": { "type": "integer", "minimum": 320 },
              "height": { "type": "integer", "minimum": 320 },
              "label": { "type": "string" }
            }
          },
          "notes": { "type": "string" },
          "path": { "type": "string" },
          "url": { "type": "string" }
        }
      }
    },
    "preview": {
      "type": "object",
      "additionalProperties": false,
      "required": ["url"],
      "properties": {
        "url": { "type": "string" },
        "command": {
          "oneOf": [
            { "type": "string" },
            {
              "type": "array",
              "items": { "type": "string" }
            }
          ]
        },
        "readiness": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "timeout_seconds": { "type": "number", "exclusiveMinimum": 0 },
            "interval_seconds": { "type": "number", "exclusiveMinimum": 0 },
            "expect_status": { "type": "integer", "minimum": 100, "maximum": 599 }
          }
        }
      }
    }
  }
}
