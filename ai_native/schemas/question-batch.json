{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["needs_user_input", "summary", "questions"],
  "properties": {
    "needs_user_input": {
      "type": "boolean"
    },
    "summary": {
      "type": "string"
    },
    "questions": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "maxItems": 3
    }
  }
}
