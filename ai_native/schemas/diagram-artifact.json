{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["title", "diagram", "legend", "assumptions"],
  "properties": {
    "title": { "type": "string" },
    "diagram": { "type": "string" },
    "legend": {
      "type": "array",
      "items": { "type": "string" }
    },
    "assumptions": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}

