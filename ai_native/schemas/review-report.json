{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["verdict", "summary", "findings", "required_changes"],
  "properties": {
    "verdict": {
      "type": "string",
      "enum": ["approved", "changes_required"]
    },
    "summary": { "type": "string" },
    "findings": {
      "type": "array",
      "items": { "type": "string" }
    },
    "required_changes": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}

